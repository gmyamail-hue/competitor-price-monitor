# ========== 复制本文件为 .env.local（本地测试用）==========
# 在 Vercel 网站 → 项目 → Settings → Environment Variables 里填写同样内容

# --- Upstash Redis（存监控网址、暂停状态）---
# 在 Vercel：Storage → 创建 Upstash Redis → 会自动注入下面两个变量
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Resend 发邮件（免费注册 https://resend.com）---
RESEND_API_KEY=
# 发件人（需在 Resend 验证域名；测试可用 onboarding@resend.dev）
MAIL_FROM=onboarding@resend.dev
# 你的收件邮箱
MAIL_TO=你的邮箱@example.com

# --- 管理密码：网页上暂停/恢复、添加网址时要输入 ---
ADMIN_PIN=123456

# --- Vercel 定时任务安全密钥（随便填一串长字符）---
# 在 Vercel 项目里添加同名变量后，定时任务才会执行
CRON_SECRET=请改成一串随机密码
